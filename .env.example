# ── REQUIRED ──────────────────────────────────────────────────────────────
# Anthropic — https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Stripe — https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Stripe Price IDs — create in Stripe Dashboard → Products
# One price per tier, set as "Recurring" subscription
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_starter_id_here
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_pro_id_here
NEXT_PUBLIC_STRIPE_PRICE_AGENCY=price_agency_id_here

# ── OPTIONAL ──────────────────────────────────────────────────────────────
# Your live app URL (update after first Vercel deploy)
NEXT_PUBLIC_APP_URL=https://vaultiq.vercel.app

# Stripe coupon ID for 50% off beta (create in Stripe Dashboard → Coupons)
STRIPE_BETA_COUPON=FOUNDING50

# Resend — https://resend.com → API Keys (for welcome/beta emails)
RESEND_API_KEY=re_your-resend-key

# Supabase — https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

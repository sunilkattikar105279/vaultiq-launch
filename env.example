# ══════════════════════════════════════════════════════
# VaultIQ — Environment Variables
# LOCAL:  copy to .env.local and fill in values
# VERCEL: Settings → Environment Variables → add each
# ══════════════════════════════════════════════════════

# ── REQUIRED: Anthropic ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── REQUIRED: Stripe secret key ───────────────────────
# Stripe Dashboard → Developers → API Keys → Secret key
STRIPE_SECRET_KEY=sk_test_your-secret-key

# ── REQUIRED: Stripe Price IDs ────────────────────────
# Add BOTH versions of each price ID (server + client)
# Stripe → Products → click product → copy Price ID (price_xxx)

STRIPE_PRICE_STARTER=price_starter_id_here
STRIPE_PRICE_PRO=price_pro_id_here
STRIPE_PRICE_AGENCY=price_agency_id_here

# Also add with NEXT_PUBLIC_ prefix so client can read them
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_starter_id_here
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_pro_id_here
NEXT_PUBLIC_STRIPE_PRICE_AGENCY=price_agency_id_here

# ── REQUIRED: Your app URL ────────────────────────────
NEXT_PUBLIC_APP_URL=https://vaultiq-launch.vercel.app

# ── OPTIONAL: Stripe webhook ──────────────────────────
# Stripe → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-signing-secret

# ── OPTIONAL: 50% off beta coupon ────────────────────
# Create in Stripe → Coupons → paste the coupon ID (not the code)
# Leave blank if you don't want auto-discount applied
STRIPE_BETA_COUPON=

# ── OPTIONAL: Email ───────────────────────────────────
RESEND_API_KEY=re_your-key
